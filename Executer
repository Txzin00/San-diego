local function criarBotao(nome, texto, posY)
    local btn = Instance.new("TextButton")
    btn.Name = nome
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.Position = UDim2.new(0.05, 0, 0, posY)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = texto .. " [OFF]"
    btn.TextColor3 = Color3.fromRGB(255, 100, 100)
    btn.TextSize = 14
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = ContentFrame
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    return btn
end

local AutoFarmBtn = criarBotao("AutoFarmBtn", "Auto Farm", 20)
local AntiAfkBtn = criarBotao("AntiAfkBtn", "Anti AFK", 85)

-- ARRASTAR E ANIMAR
local dragging, dragInput, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

local minimizado = false
local tamanhoOriginal = MainFrame.Size

MinBtn.MouseButton1Click:Connect(function()
    minimizado = not minimizado
    local targetSize = minimizado and UDim2.new(0, 250, 0, 35) or tamanhoOriginal
    TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingStyle.Out), {Size = targetSize}):Play()
    MinBtn.Text = minimizado and "+" or "_"
    ContentFrame.Visible = not minimizado
end)

-- SISTEMA DO FARM E CLIQUES
local function simularTeclaE(vezes)
    local VirtualInputManager = game:GetService("VirtualInputManager")
    for i = 1, vezes do
        if not autoFarmActive then breakend
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.25)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(0.1)
    end
end

local function andarAte(targetX, targetY, targetZ, velocidade)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = character.HumanoidRootPart
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then humanoid.WalkSpeed = velocidade end
    
    local targetPos = Vector3.new(targetX, targetY, targetZ)
    
    while autoFarmActive and (Vector3.new(hrp.Position.X, targetY, hrp.Position.Z) - targetPos).Magnitude > 3 do
        if character and hrp then
            hrp.CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z)
            if humanoid then humanoid:MoveTo(targetPos) end
        end
        task.wait()
    end
end

-- BOTOES ATIVADORES
AntiAfkBtn.MouseButton1Click:Connect(function()
    antiAfkActive = not antiAfkActive
    if antiAfkActive then
        AntiAfkBtn.Text = "Anti AFK [ON]"
        AntiAfkBtn.TextColor3 = Color3.fromRGB(100, 255, 100)
        task.spawn(function()
            while antiAfkActive do
                task.wait(60)
                if not antiAfkActive then break end
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
                    LocalPlayer.Character:FindFirstChildOfClass("Humanoid").Jump = true
                end
            end
        end)
    else
        AntiAfkBtn.Text = "Anti AFK [OFF]"
        AntiAfkBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end)

AutoFarmBtn.MouseButton1Click:Connect(function()
    autoFarmActive = not autoFarmActive
    if autoFarmActive then
        AutoFarmBtn.Text = "Auto Farm [ON]"
        AutoFarmBtn.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        task.spawn(function()
            while autoFarmActive do
                -- 1ª Rota
                andarAte(6820, 0, 21, 200)
                if not autoFarmActive then break end
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(6820, 18, 21)
                end
                simularTeclaE(5)
                
                -- 2ª Rota
                andarAte(209, 0, -44, 200)
                if not autoFarmActive then break end
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(209, 18, -44)
                end
                simularTeclaE(1)
                
                -- 3ª Rota
                andarAte(6807, 0, -36, 200)
                if not autoFarmActive then break end
                if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(6807, 18, -36)
                end
                simularTeclaE(1)
                
                task.wait(0.5)
            end
        end)
    else
        AutoFarmBtn.Text = "Auto Farm [OFF]"
        AutoFarmBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
            LocalPlayer.Character:FindFirstChildOfClass("Humanoid").WalkSpeed = 16
        end
    end
end)
