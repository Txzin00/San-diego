-- Estilo Padrão dos Botões de Função
local function criarBotao(nome, texto, posY)
    local btn = Instance.new("TextButton")
    btn.Name = nome
    btn.Size = UDim2.new(0.9, 0, 0, 45)
    btn.Position = UDim2.new(0.05, 0, 0, posY)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    btn.Text = texto .. " [OFF]"
    btn.TextColor3 = Color3.fromRGB(255, 100, 100)
    btn.TextSize = 14
    btn.Font = Enum.Font.SourceSansBold
    btn.Parent = ContentFrame
    
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = btn
    return btn
end

local AutoFarmBtn = criarBotao("AutoFarmBtn", "Auto Farm", 20)
local AntiAfkBtn = criarBotao("AntiAfkBtn", "Anti AFK", 85)

-- ==========================================
-- SISTEMA DE ARRASTAR (DRAG) & ANIMAR (TWEEN)
-- ==========================================

local dragging, dragInput, dragStart, startPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = MainFrame.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then dragging = false end
        end)
    end
end)

TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        MainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)

-- Animação de Minimizar / Maximizar
local minimizado = false
local tamanhoOriginal = MainFrame.Size

MinBtn.MouseButton1Click:Connect(function()
    minimizado = not minimizado
    local targetSize = minimizado and UDim2.new(0, 250, 0, 35) or tamanhoOriginal
    
    local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingStyle.Out)
    local tween = TweenService:Create(MainFrame, tweenInfo, {Size = targetSize})
    tween:Play()
    
    MinBtn.Text = minimizado and "+" or "_"
    ContentFrame.Visible = not minimizado
end)

-- ==========================================
-- LÓGICA DAS FUNÇÕES (ANTI-AFK & AUTO FARM)
-- ==========================================

-- Função auxiliar para simular o pressionamento da tecla E
local function simularTeclaE(vezes)
    local VirtualInputManager = game:GetService("VirtualInputManager")
    for i = 1, vezes do
        if not autoFarmActive then break end
        VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
        task.wait(0.25)
        VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
        task.wait(0.1) -- Pequena pausa entre cliques
    end
end

-- Função auxiliar para mover o personagem até as coordenadas exatas
local function andarAte(targetX, targetY, targetZ, velocidade)
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = character.HumanoidRootPart
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if humanoid then humanoid.WalkSpeed = velocidade end
    
    local targetPos = Vector3.new(targetX, targetY, targetZ)
    
    -- Loop de movimento preciso por frame
    while autoFarmActive and (Vector3.new(hrp.Position.X, targetY, hrp.Position.Z) - targetPos).Magnitude > 3 do
        if character and hrp then
            -- Força a posição exata da camada Y desejada enquanto caminha
            hrp.CFrame = CFrame.new(hrp.Position.X, targetY, hrp.Position.Z)
            if humanoid then
                humanoid:MoveTo(targetPos)
            end
        end
        task.wait()
    end
end

-- Ativador Anti-AFK (Pula a cada 1 minuto)
AntiAfkBtn.MouseButton1Click:Connect(function()
    antiAfkActive = not antiAfkActive
    if antiAfkActive then
        AntiAfkBtn.Text = "Anti AFK [ON]"
        AntiAfkBtn.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        task.spawn(function()
            while antiAfkActive do
                task.wait(60) -- 1 minuto
                if not antiAfkActive then break end
                local character = LocalPlayer.Character
                if character and character:FindFirstChildOfClass("Humanoid") then
                    character:FindFirstChildOfClass("Humanoid").Jump = true
                end
            end
        end)
    else
        AntiAfkBtn.Text = "Anti AFK [OFF]"
        AntiAfkBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
    end
end)

-- Ativador Auto Farm
AutoFarmBtn.MouseButton1Click:Connect(function()
    autoFarmActive = not autoFarmActive
    if autoFarmActive then
        AutoFarmBtn.Text = "Auto Farm [ON]"
        AutoFarmBtn.TextColor3 = Color3.fromRGB(100, 255, 100)
        
        task.spawn(function()
            while autoFarmActive do
                -- 1ª Rota: Anda na camada Y: 0 até o destino final, depois sobe para Y: 18
                andarAte(6820, 0, 21, 200)
                if not autoFarmActive then break end
                -- Sobe para a camada original e executa a ação do E
                local character = LocalPlayer.Character
                if character and character:FindFirstChild("HumanoidRootPart") then
                    character.HumanoidRootPart.CFrame = CFrame.new(6820, 18, 21)
                end
                simularTeclaE(5)
                
                -- 2ª Rota: Volta para Y: 0 e anda até a próxima coordenada
                andarAte(209, 0, -44, 200)
                if not autoFarmActive then break end
                -- Sobe para Y: 18 e aperta E
                if character and character:FindFirstChild("HumanoidRootPart") then
                    character.HumanoidRootPart.CFrame = CFrame.new(209, 18, -44)
                end
                simularTeclaE(1)
                
                -- 3ª Rota: Volta para Y: 0 e vai até o último ponto
                andarAte(6807, 0, -36, 200)
                if not autoFarmActive then break end
                -- Sobe para Y: 18 e aperta E final antes de reiniciar o ciclo
                if character and character:FindFirstChild("HumanoidRootPart") then
                    character.HumanoidRootPart.CFrame = CFrame.new(6807, 18, -36)
                end
                simularTeclaE(1)
                
                task.wait(0.5)
            end
        end)
    else
        AutoFarmBtn.Text = "Auto Farm [OFF]"
        AutoFarmBtn.TextColor3 = Color3.fromRGB(255, 100, 100)
        
        -- Restaura velocidade padrão ao desligar
        local character = LocalPlayer.Character
        if character and character:FindFirstChildOfClass("Humanoid") then
            character:FindFirstChildOfClass("Humanoid").WalkSpeed = 16
        end
    end
end)
